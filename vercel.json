{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "nextjs",

  "regions": ["bom1"],

  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": ".next",

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],

  "crons": []
}

# ============================================================
# DIGITAL HEROES — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase (Architectural Choice) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Razorpay (Architectural Choice — replaces Stripe for Indian payment processing) ---
# Key ID is public (safe for frontend) — like Stripe's publishable key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
# Key Secret is private (server-side only) — NEVER expose this
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Razorpay Plan IDs — created in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_PLAN_MONTHLY=plan_placeholder_monthly
RAZORPAY_PLAN_YEARLY=plan_placeholder_yearly

# --- Subscription Pricing (Unresolved — configurable at runtime) ---
# Format: smallest currency unit (e.g. pence, cents)
# Examples: 999 = £9.99, 9900 = £99.00
SUBSCRIPTION_PRICE_MONTHLY_AMOUNT=0
SUBSCRIPTION_PRICE_YEARLY_AMOUNT=0
SUBSCRIPTION_CURRENCY=gbp

# --- Prize Pool (Unresolved — configurable at runtime) ---
# Percentage of subscription revenue that goes to prize pool (e.g. 50 = 50%)
PRIZE_POOL_CONTRIBUTION_PERCENT=0

# --- Email — Resend (Phase 11) ---
# Sign up at https://resend.com, create an API key, and verify your domain.
# In dev mode (re_placeholder), emails are logged to console instead of sent.
RESEND_API_KEY=re_placeholder
# Format: "Display Name <email@yourdomain.com>" — domain must be verified in Resend
EMAIL_FROM=Digital Heroes <noreply@yourdomain.com>

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Admin Seed (Architectural Choice) ---
# Email and password used when running the admin seed script (Phase 3)
ADMIN_SEED_EMAIL=admin@digitalheroes.co.in
ADMIN_SEED_PASSWORD=change-me-before-seeding
